# Interactive Brokers Configuration
IB_HOST=localhost
IB_PORT=7497
IB_CLIENT_ID=1
IB_ACCOUNT=DU123456
IB_PAPER=true

# Trading Configuration
SYMBOLS=SPY,QQQ,IWM,GLD,TLT
ENVIRONMENT=paper
TRADING_HOURS_START=09:30
TRADING_HOURS_END=16:00
TIMEZONE=America/New_York

# Risk Management
MAX_NOTIONAL=1000000
MAX_QTY=1000
PRICE_BAND_BPS=50
ORDERS_PER_SEC=10
DRAWDOWN_LIMIT=0.05
MAX_OPEN_ORDERS=50

# Database Configuration
POSTGRES_DSN=postgresql://user:password@localhost:5432/trading
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKERS=localhost:9092

# Azure Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
KEY_VAULT_NAME=hft-keyvault
ACR_NAME=hftacr

# Monitoring
APP_INSIGHTS_CONN=InstrumentationKey=your-key;IngestionEndpoint=https://your-endpoint
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
CORRELATION_ID_HEADER=X-Correlation-ID

# Feature Flags
ENABLE_KILL_SWITCH=true
ENABLE_PRE_TRADE_RISK=true
ENABLE_THROTTLING=true
ENABLE_METRICS=true
ENABLE_TRACING=true

# Market Data
MD_BUFFER_SIZE=10000
MD_BATCH_SIZE=100
MD_FLUSH_INTERVAL=1.0

# Order Management
ORDER_TIMEOUT=30
ORDER_RETRY_ATTEMPTS=3
ORDER_RETRY_DELAY=1.0

# Strategy Configuration
SIGNAL_THRESHOLD=2.0
LOOKBACK_PERIOD=60
VOLATILITY_WINDOW=20
MOMENTUM_WINDOW=5

# Network Configuration
CONNECT_TIMEOUT=10
READ_TIMEOUT=30
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5.0
